BOT_TYPE=iterative-deepening
BOT_DEPTH=5

# Standard Elo evaluation (all opponent types)
EVAL_BOT=minimax
EVAL_BOT_DEPTH=4
EVAL_BOT_EVAL=basic
EVAL_BOT_THREADS=1
EVAL_OPPONENT_ENGINE=stockfish
EVAL_OPPONENT_KIND=stockfish
EVAL_LEVELS=1320,1500,1700,1900
EVAL_GAMES_PER_LEVEL=8
EVAL_PARALLEL_GAMES=1
EVAL_SF_MOVETIME_MS=120
EVAL_SF_HASH=64
EVAL_SF_THREADS=1
EVAL_MAX_PLIES=300
EVAL_STOP_IF_SCORE_RATE_BELOW=0.40
EVAL_PGN_DIR=logs/elo-pgn
EVAL_OUTPUT_JSON=logs/elo-report.json

# Rodent IV evaluation (UCI Elo presets, minimum 800)
EVAL_RODENT_BOT=iterdeep
EVAL_RODENT_BOT_DEPTH=5
EVAL_RODENT_BOT_EVAL=phased
EVAL_RODENT_BOT_THREADS=4
EVAL_RODENT_ENGINE=/app/engines/rodent
EVAL_RODENT_KIND=rodent
EVAL_RODENT_LEVELS=elo:800,elo:900,elo:1000,elo:1100,elo:1200,elo:1300,elo:1400
EVAL_RODENT_GAMES_PER_LEVEL=8
EVAL_RODENT_PARALLEL_GAMES=8
EVAL_RODENT_MOVETIME_MS=120
EVAL_RODENT_HASH=64
EVAL_RODENT_THREADS=1
EVAL_RODENT_MAX_PLIES=300
EVAL_RODENT_STOP_IF_SCORE_RATE_BELOW=0.40
EVAL_RODENT_PGN_DIR=logs/elo-rodent-pgn
EVAL_RODENT_OUTPUT_JSON=logs/elo-rodent-report.json